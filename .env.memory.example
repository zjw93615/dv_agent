# Memory System 配置示例
# 复制此文件为 .env 并填入实际值

# ========== Redis 配置 ==========
MEMORY_REDIS_URL=redis://localhost:6379
MEMORY_REDIS_DB=0

# ========== PostgreSQL 配置 ==========
MEMORY_POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/memory_db

# ========== Milvus 配置 ==========
MEMORY_MILVUS_HOST=localhost
MEMORY_MILVUS_PORT=19530
MEMORY_MILVUS_COLLECTION=agent_memories

# ========== 嵌入模型配置 ==========
# 使用本地模型（推荐，无需 API）
MEMORY_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MEMORY_EMBEDDING_DIMENSION=384

# 或使用 OpenAI API
# MEMORY_EMBEDDING_MODEL=openai
# OPENAI_API_KEY=sk-your-api-key
# MEMORY_EMBEDDING_DIMENSION=1536

# ========== 短期记忆配置 ==========
# 消息 TTL（秒）
MEMORY_SHORT_TERM_TTL=86400
# 上下文最大消息数
MEMORY_MAX_CONTEXT_MESSAGES=50

# ========== 长期记忆配置 ==========
# 重要性衰减系数（lambda）
MEMORY_IMPORTANCE_DECAY_LAMBDA=0.05
# 软删除天数
MEMORY_SOFT_FORGET_DAYS=7
# 归档天数
MEMORY_ARCHIVE_DAYS=30
# 硬删除天数
MEMORY_HARD_DELETE_DAYS=90

# ========== 检索配置 ==========
# 默认 top-k
MEMORY_DEFAULT_TOP_K=10
# 重排序模型
MEMORY_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# 查询缓存 TTL（秒）
MEMORY_QUERY_CACHE_TTL=300

# ========== LLM 配置（用于记忆提取） ==========
# 使用 OpenAI
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-4o-mini

# 或使用本地 Ollama
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ========== 后台任务配置 ==========
# 维护任务间隔（秒）
MEMORY_MAINTENANCE_INTERVAL=3600
# 一致性检查间隔（秒）
MEMORY_CONSISTENCY_CHECK_INTERVAL=86400

# DV-Agent Production Environment Configuration
# Copy to .env.production and fill in the values

# ==================== Application ====================
DV_AGENT_APP_NAME=dv-agent
DV_AGENT_APP_VERSION=0.1.0
DV_AGENT_DEBUG=false
DV_AGENT_ENVIRONMENT=production

# ==================== PostgreSQL (Auth & Session) ====================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dv_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# ==================== LLM Providers ====================
# Primary provider: openai, deepseek, or ollama
LLM_PRIMARY_PROVIDER=openai

# OpenAI Configuration (REQUIRED if using openai)
OPENAI_API_KEY=sk-your-production-api-key
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_MODEL=gpt-4o

# DeepSeek Configuration (optional)
DEEPSEEK_API_KEY=
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_MODEL=deepseek-chat

# Ollama Configuration (for local LLM)
LLM_OLLAMA_BASE_URL=http://ollama:11434
LLM_OLLAMA_MODEL=llama3.2

# LLM Settings
LLM_DEFAULT_TEMPERATURE=0.7
LLM_DEFAULT_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60.0
LLM_MAX_RETRIES=3

# ==================== A2A Server ====================
A2A_HOST=0.0.0.0
A2A_PORT=8080
A2A_WORKERS=4
A2A_CONNECTION_TIMEOUT=30.0
A2A_READ_TIMEOUT=120.0
A2A_ENABLE_CORS=true

# ==================== Agent Settings ====================
AGENT_MAX_ITERATIONS=10
AGENT_THINKING_TIMEOUT=30.0
AGENT_ACTION_TIMEOUT=60.0
AGENT_SESSION_TTL=3600
AGENT_CONTEXT_WINDOW=20

# ==================== Intent Recognition ====================
INTENT_USE_EMBEDDING=false
INTENT_USE_LLM_FALLBACK=true
INTENT_RULE_CONFIDENCE_THRESHOLD=0.7
INTENT_EMBEDDING_CONFIDENCE_THRESHOLD=0.85
INTENT_LLM_CONFIDENCE_THRESHOLD=0.6

# ==================== Tools ====================
TOOL_ENABLE_CALCULATOR=true
TOOL_ENABLE_DATETIME=true
TOOL_ENABLE_WEB_SEARCH=false
TOOL_MCP_CONNECTION_TIMEOUT=10.0
TOOL_MCP_AUTO_RECONNECT=true

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true
LOG_FILE_PATH=/app/logs/dv-agent.log
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5

# ==================== RAG (Retrieval-Augmented Generation) ====================
# Enable RAG service
RAG_ENABLED=true

# Embedding Model Configuration
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_MODEL_PATH=./models/bge-m3
RAG_EMBEDDING_DEVICE=cuda
RAG_EMBEDDING_BATCH_SIZE=32
RAG_EMBEDDING_MAX_LENGTH=8192

# MinIO Object Storage (use Docker service name)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
MINIO_BUCKET_NAME=documents

# PostgreSQL (RAG Documents - use Docker service name)
RAG_POSTGRES_HOST=postgres
RAG_POSTGRES_PORT=5432
RAG_POSTGRES_DATABASE=dv_agent
RAG_POSTGRES_USER=postgres
RAG_POSTGRES_PASSWORD=postgres123

# Milvus Vector Database (use Docker service name)
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# Retrieval Configuration
RAG_DEFAULT_TOP_K=10
RAG_USE_RERANKING=true
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER_MODEL_PATH=./models/bge-reranker-v2-m3
RAG_USE_QUERY_EXPANSION=true
RAG_EXPANSION_COUNT=3

# Search Weights
RAG_DENSE_WEIGHT=0.4
RAG_SPARSE_WEIGHT=0.3
RAG_BM25_WEIGHT=0.3

# Cache Configuration
RAG_CACHE_ENABLED=true
RAG_CACHE_TTL=300
RAG_LOCAL_CACHE_SIZE=1000

# Document Processing
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_MAX_FILE_SIZE_MB=50

# Tenant Quotas
RAG_MAX_DOCUMENTS_PER_TENANT=1000
RAG_MAX_STORAGE_MB_PER_TENANT=5000
RAG_MAX_CHUNKS_PER_TENANT=100000

# ==================== Monitoring ====================
GRAFANA_PASSWORD=your-secure-grafana-password
